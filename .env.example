# Charles Schwab Platform - Required Environment Variables
# Copy to your deployment configuration (Cloud Run env vars, .env, etc.)

# ── Runtime Target (REQUIRED) ──
# 优先使用 QSL_RUNTIME_TARGET_JSON（跨平台共享），否则使用 RUNTIME_TARGET_JSON
RUNTIME_TARGET_JSON={"platform_id":"schwab","strategy_profile":"soxl_soxx_trend_income","execution_mode":"live","account_scope":"default","dry_run_only":true}

# ── Schwab API Credentials (REQUIRED for execution) ──
SCHWAB_API_KEY=<from-secret-manager>
SCHWAB_APP_SECRET=<from-secret-manager>

# ── Notification ──
# QSL_GLOBAL_TELEGRAM_CHAT_ID 和 QSL_NOTIFY_LANG 是跨平台共享的 QSL_ 前缀变量，
# 设置后会覆盖 GLOBAL_TELEGRAM_CHAT_ID 和 NOTIFY_LANG。
TELEGRAM_TOKEN=<from-secret-manager>
GLOBAL_TELEGRAM_CHAT_ID=
QSL_GLOBAL_TELEGRAM_CHAT_ID=
NOTIFY_LANG=zh
QSL_NOTIFY_LANG=
NOTIFICATION_CHANNEL=telegram

# ── Execution Control ──
SCHWAB_DRY_RUN_ONLY=false
SCHWAB_FORCE_RUN=false
SCHWAB_SAFE_HAVEN_CASH_SUBSTITUTE_THRESHOLD_USD=1000.0
SCHWAB_MIN_RESERVED_CASH_USD=0.0
SCHWAB_RESERVED_CASH_RATIO=0.0
SCHWAB_MIN_ORDER_NOTIONAL_USD=100.0

# ── Strategy Plugin ──
STRATEGY_PLUGIN_MOUNTS_JSON=
QSL_STRATEGY_PLUGIN_MOUNTS_JSON=
STRATEGY_PLUGIN_ALERT_TELEGRAM_BOT_TOKEN=<from-secret-manager>
QSL_STRATEGY_PLUGIN_ALERT_TELEGRAM_BOT_TOKEN=
STRATEGY_PLUGIN_ALERT_TELEGRAM_CHAT_IDS=

# ── Execution Report ──
EXECUTION_REPORT_OUTPUT_DIR=/tmp/quant_runtime_reports
EXECUTION_REPORT_GCS_URI=gs://qsl-runtime-logs-shared/execution-reports
QSL_EXECUTION_REPORT_GCS_URI=
